# Server-hosted frontend mode.
ARGUS_SERVER_ADDR=0.0.0.0:3010
ARGUS_WEB_DIST_DIR=/opt/arguswing/web
DATABASE_URL=postgres://argus:argus_dev@127.0.0.1:5432/argus_dev
TRACE_DIR=/opt/arguswing/traces

# OAuth2 authorization-code login.
# Systemd loads this file through deploy/systemd/arguswing.service:
#   EnvironmentFile=/etc/arguswing/arguswing.env
ARGUS_OAUTH_ENABLED=true
ARGUS_OAUTH_BASE_URL=https://auth.example.test
ARGUS_OAUTH_CLIENT_ID=replace-me
ARGUS_OAUTH_CLIENT_SECRET=replace-me
ARGUS_OAUTH_REDIRECT_URI=https://argus.example.test/auth/callback
ARGUS_OAUTH_SCOPE=base.profile
ARGUS_OAUTH_COOKIE_SECURE=true

# Local development only. Do not enable together with OAuth2.
# ARGUS_DEV_AUTH_ENABLED=true

# Nginx frontend mode:
# ARGUS_SERVER_ADDR=127.0.0.1:3010
# DATABASE_URL=postgres://argus:argus_dev@127.0.0.1:5432/argus_dev
# TRACE_DIR=/opt/arguswing/traces
