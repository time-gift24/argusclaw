[Unit]
Description=ArgusWing server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=arguswing
Group=arguswing
WorkingDirectory=/opt/arguswing
ExecStart=/opt/arguswing/bin/argus-server --config /etc/arguswing/arguswing.toml
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/arguswing/data /opt/arguswing/traces /etc/arguswing
UMask=0077

[Install]
WantedBy=multi-user.target
