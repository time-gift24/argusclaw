[Unit]
Description=ArgusWing server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=arguswing
Group=arguswing
WorkingDirectory=/opt/arguswing
EnvironmentFile=/etc/arguswing/arguswing.env
ExecStart=/opt/arguswing/bin/argus-server
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/arguswing/data /opt/arguswing/traces
UMask=0077

[Install]
WantedBy=multi-user.target
